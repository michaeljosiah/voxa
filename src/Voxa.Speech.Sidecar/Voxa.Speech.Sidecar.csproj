<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <PropertyGroup Label="Package">
    <PackageId>Voxa.Speech.Sidecar</PackageId>
    <Version>0.1.0-alpha</Version>
    <Authors>Voxa contributors</Authors>
    <Description>Expressive / multilingual / voice-cloning TTS for the Voxa pipeline via an out-of-process sidecar (XTTS / OpenVoice), driven over a tiny stdio protocol — the same out-of-process isolation Piper uses. Opt-in heavy tier (VVL-002): bring your own sidecar binary (or run the bundled Python script in dev) until pinned frozen builds ship.</Description>
    <PackageTags>voxa;voice;ai;tts;cloning;expressive;sidecar;xtts</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" Version="10.0.7" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="10.0.7" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Voxa.Core\Voxa.Core.csproj" />
    <ProjectReference Include="..\Voxa.Speech.Abstractions\Voxa.Speech.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <!-- Ship the sidecar source so users (and the PyInstaller freeze step) have it. -->
    <None Include="sidecar\**" Pack="true" PackagePath="sidecar\" CopyToOutputDirectory="PreserveNewest" />
    <InternalsVisibleTo Include="Voxa.Speech.Sidecar.Tests" />
  </ItemGroup>

</Project>
