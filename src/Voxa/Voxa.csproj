<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <PropertyGroup Label="Package">
    <PackageId>Voxa</PackageId>
    <Version>0.1.0-alpha</Version>
    <Authors>Voxa contributors</Authors>
    <Description>Batteries-included Voxa package. One package reference: AddVoxa(cfg) + MapVoxaVoice("/voice").UseDefaults() gives a working voice bot with STT, TTS, VAD, and an OpenAI chat agent — no knowledge of frames required.</Description>
    <PackageTags>voxa;voice;ai;aspnetcore;openai;speech</PackageTags>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
  </PropertyGroup>

  <!-- Speech providers and VAD — the heavy closure. -->
  <ItemGroup>
    <ProjectReference Include="..\Voxa.AspNetCore\Voxa.AspNetCore.csproj" />
    <ProjectReference Include="..\Voxa.Speech.OpenAI\Voxa.Speech.OpenAI.csproj" />
    <ProjectReference Include="..\Voxa.Speech.AssemblyAI\Voxa.Speech.AssemblyAI.csproj" />
    <ProjectReference Include="..\Voxa.Speech.Aws\Voxa.Speech.Aws.csproj" />
    <ProjectReference Include="..\Voxa.Speech.Deepgram\Voxa.Speech.Deepgram.csproj" />
    <ProjectReference Include="..\Voxa.Speech.Gladia\Voxa.Speech.Gladia.csproj" />
    <ProjectReference Include="..\Voxa.Speech.Google\Voxa.Speech.Google.csproj" />
    <ProjectReference Include="..\Voxa.Speech.Groq\Voxa.Speech.Groq.csproj" />
    <ProjectReference Include="..\Voxa.Speech.Speechmatics\Voxa.Speech.Speechmatics.csproj" />
    <ProjectReference Include="..\Voxa.Speech.Together\Voxa.Speech.Together.csproj" />
    <ProjectReference Include="..\Voxa.Speech.Azure\Voxa.Speech.Azure.csproj" />
    <ProjectReference Include="..\Voxa.Speech.ElevenLabs\Voxa.Speech.ElevenLabs.csproj" />
    <ProjectReference Include="..\Voxa.Speech.Mistral\Voxa.Speech.Mistral.csproj" />
    <ProjectReference Include="..\Voxa.Audio.SileroVad\Voxa.Audio.SileroVad.csproj" />
    <!-- Local/offline speech tier (VLS-001): no API keys, no network after first-run download. -->
    <ProjectReference Include="..\Voxa.Speech.WhisperCpp\Voxa.Speech.WhisperCpp.csproj" />
    <!-- Heavy local STT (VLS-009): Voxtral-Mini-4B-Realtime via a local vLLM server; GPU-gated default in Studio. -->
    <ProjectReference Include="..\Voxa.Speech.Voxtral\Voxa.Speech.Voxtral.csproj" />
    <ProjectReference Include="..\Voxa.Speech.Piper\Voxa.Speech.Piper.csproj" />
    <ProjectReference Include="..\Voxa.Speech.Kokoro\Voxa.Speech.Kokoro.csproj" />
    <!-- Telephony transport (VTL-001): MapVoxaTwilioVoice + the shared telephony base. Opt-in via the
         endpoint (not the provider registry), but bundled so a meta-package host can map a phone route. -->
    <ProjectReference Include="..\Voxa.Transports.Telephony\Voxa.Transports.Telephony.csproj" />
    <ProjectReference Include="..\Voxa.Transports.Twilio\Voxa.Transports.Twilio.csproj" />
  </ItemGroup>

  <!-- OpenAI client for the default chat-agent factory. -->
  <ItemGroup>
    <PackageReference Include="OpenAI" Version="2.10.0" />
    <PackageReference Include="Microsoft.Extensions.AI.OpenAI" Version="10.5.2" />
  </ItemGroup>

</Project>
