{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/forms/**",
              "components/voice/**",
              "ui_kits/console/**",
              "ui_kits/studio/**",
              "ui_kits/website/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cascadia Code|Inter))/i]",
        "message": "Font not provided by the design system. Available: Cascadia Code, Inter."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|style|className|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|pulse|halo|ok|warn|danger|info)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'pulse' | 'halo' | 'ok' | 'warn' | 'danger' | 'info'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|children|disabled|onClick|type|style|className|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, icon, children, disabled, onClick, type, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|ghost|danger)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'ghost' | 'danger'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit)$/]",
        "message": "<Button> type must be one of 'button' | 'submit'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:padded|interactive|glow|children|onClick|style|className|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: padded, interactive, glow, children, onClick, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='CodeBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:code|file|badge|actions|style|className|key|ref|className|style|children)$/]",
        "message": "<CodeBlock> doesn't accept that prop. Declared props: code, file, badge, actions, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|outline|label|children|disabled|onClick|style|className|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: size, outline, label, children, disabled, onClick, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|error|mono|type|value|defaultValue|placeholder|onChange|disabled|style|className|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, hint, error, mono, type, value, defaultValue, placeholder, onChange, disabled, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricStat'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|unit|delta|deltaTone|style|className|key|ref|className|style|children)$/]",
        "message": "<MetricStat> doesn't accept that prop. Declared props: label, value, unit, delta, deltaTone, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricStat'] > JSXAttribute[name.name='deltaTone'] > Literal[value!=/^(?:good|bad|flat)$/]",
        "message": "<MetricStat> deltaTone must be one of 'good' | 'bad' | 'flat'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PipelineFlow'] > JSXAttribute > JSXIdentifier[name!=/^(?:nodes|running|activeIndex|style|className|key|ref|className|style|children)$/]",
        "message": "<PipelineFlow> doesn't accept that prop. Declared props: nodes, running, activeIndex, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='PipelineNode'] > JSXAttribute > JSXIdentifier[name!=/^(?:stage|kind|name|meta|active|style|className|key|ref|className|style|children)$/]",
        "message": "<PipelineNode> doesn't accept that prop. Declared props: stage, kind, name, meta, active, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='PipelineNode'] > JSXAttribute[name.name='stage'] > Literal[value!=/^(?:vad|stt|agent|tts|out|audio|llm)$/]",
        "message": "<PipelineNode> stage must be one of 'vad' | 'stt' | 'agent' | 'tts' | 'out' | 'audio' | 'llm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|options|value|defaultValue|onChange|disabled|style|className|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, hint, options, value, defaultValue, onChange, disabled, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|label|style|className|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: status, label, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:live|connecting|idle|ended|error)$/]",
        "message": "<StatusPill> status must be one of 'live' | 'connecting' | 'idle' | 'ended' | 'error'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|defaultChecked|onChange|label|disabled|style|className|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, defaultChecked, onChange, label, disabled, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:tabs|active|defaultTab|onChange|style|className|key|ref|className|style|children)$/]",
        "message": "<Tabs> doesn't accept that prop. Declared props: tabs, active, defaultTab, onChange, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TranscriptLine'] > JSXAttribute > JSXIdentifier[name!=/^(?:role|text|time|partial|style|className|key|ref|className|style|children)$/]",
        "message": "<TranscriptLine> doesn't accept that prop. Declared props: role, text, time, partial, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='TranscriptLine'] > JSXAttribute[name.name='role'] > Literal[value!=/^(?:user|agent|system)$/]",
        "message": "<TranscriptLine> role must be one of 'user' | 'agent' | 'system'."
      },
      {
        "selector": "JSXOpeningElement[name.name='VoiceOrb'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|live|style|className|key|ref|className|style|children)$/]",
        "message": "<VoiceOrb> doesn't accept that prop. Declared props: size, live, style, className."
      },
      {
        "selector": "JSXOpeningElement[name.name='Waveform'] > JSXAttribute > JSXIdentifier[name!=/^(?:bars|height|live|gradient|muted|levels|style|className|key|ref|className|style|children)$/]",
        "message": "<Waveform> doesn't accept that prop. Declared props: bars, height, live, gradient, muted, levels, style, className."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
