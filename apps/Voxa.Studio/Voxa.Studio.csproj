<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <BuiltInComInteropSupport>true</BuiltInComInteropSupport>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- The VOXA mark as the Windows exe/taskbar icon (generated by tools/voxa-icon-gen.cs). -->
    <ApplicationIcon>Assets\voxa.ico</ApplicationIcon>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <!-- Not a NuGet package: Studio is a product app (VST-001), shipped from the repo. -->
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Avalonia" Version="11.3.2" />
    <PackageReference Include="Avalonia.Desktop" Version="11.3.2" />
    <PackageReference Include="Avalonia.Themes.Fluent" Version="11.3.2" />
    <PackageReference Include="Avalonia.Fonts.Inter" Version="11.3.2" />
    <!-- Avalonia.Diagnostics is dev-tooling (F12 inspector); Debug builds only. -->
    <PackageReference Include="Avalonia.Diagnostics" Version="11.3.2" Condition="'$(Configuration)' == 'Debug'" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <!-- WASAPI capture/render for the v1 Windows audio backend (MIT licensed). -->
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="10.0.9" />
    <!-- Transitive of Avalonia.FreeDesktop; 0.21.2 has GHSA-xrw6-gwf8-vvr9 (NU1903) — lift to the patched release. -->
    <PackageReference Include="Tmds.DBus.Protocol" Version="0.21.3" />
    <!-- GPU acceleration for whisper.cpp STT (the heaviest stage). The Vulkan runtime drives any modern GPU
         (NVIDIA / AMD / Intel) with no CUDA toolkit, so the Config "Device" picker's vulkan/auto options work
         out of the box. Whisper.net deploys runtime natives side-by-side, so this coexists with the CPU runtime
         (no conflict). Windows-only so the Linux CI lane stays CPU and lean; CUDA/CoreML remain opt-in (add the
         matching Whisper.net.Runtime.* package — the Device picker flags them as unavailable until you do). -->
    <PackageReference Include="Whisper.net.Runtime.Vulkan" Version="1.9.1"
                      Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
    <!-- GPU for the ONNX engines (Kokoro TTS) on Windows: the CUDA ORT runtime drives NVIDIA GPUs. The ONNX
         engine packages (Kokoro / SileroVad / Diarization.Onnx) all reference the CPU ORT (same package id)
         transitively; ExcludeAssets="all" on that id here keeps the CPU native out of THIS app's output so the
         GPU native (same managed assembly, a native carrying both CUDA and CPU EPs) is the only onnxruntime.dll
         — no duplicate. The CUDA EP needs the NVIDIA CUDA toolkit at runtime; the Config "Device" picker flags
         availability up front (OnnxDeviceProbe) and the engine fails loud per the device contract if CUDA was
         asked for but can't load. CPU still works without the toolkit (CUDA is a separate on-demand provider
         dll), so the default Silero VAD path is unaffected. The .Gpu.Windows sub-package (not the meta .Gpu) ships
         only the win-x64 ORT natives, dropping the Linux/macOS ORT .so/.dylib the meta package would add
         (~700 MB, mostly its CUDA/TensorRT providers; a small win-x64 TensorRT dll rides along, unused).
         PrivateAssets="all" keeps the
         GPU native in Studio's own output but out of Voxa.Studio.Tests, which stays lean CPU-only. Windows-only
         so the Linux CI lane stays CPU; on non-Windows the transitive CPU ORT flows normally (no exclude). -->
    <PackageReference Include="Microsoft.ML.OnnxRuntime.Gpu.Windows" Version="1.26.0" PrivateAssets="all"
                      Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.26.0" ExcludeAssets="all"
                      Condition="$([MSBuild]::IsOSPlatform('Windows'))" />
  </ItemGroup>

  <ItemGroup>
    <!-- The Voxa meta-package: AddVoxa() with every built-in provider, incl. the keyless
         local tier (WhisperCpp / Piper / Kokoro / Silero / Echo) Studio defaults to. -->
    <ProjectReference Include="..\..\src\Voxa\Voxa.csproj" />
    <!-- Smart turn detection (P0) is opt-in (a call on the turn-taking path) so it is NOT in the
         meta-package — reference it directly. StudioServices calls AddVoxaSmartTurn so the Config
         "Smart turn detection" toggle can register a classifier; the package's bundled Python sidecar
         script copies into the output via this reference. -->
    <ProjectReference Include="..\..\src\Voxa.Audio.SmartTurn\Voxa.Audio.SmartTurn.csproj" />
    <!-- Speaker segmentation (VLS-005 WS2): the Models page surfaces its pinned pyannote model for
         download/verify. Not in the meta-package (opt-in ONNX engine) — referenced directly. -->
    <ProjectReference Include="..\..\src\Voxa.Audio.Diarization.Onnx\Voxa.Audio.Diarization.Onnx.csproj" />
    <!-- The ONNX device seam (OnnxDeviceParser / OnnxDeviceProbe) behind the Config "Device" picker's
         Kokoro GPU compatibility indicator. Available transitively, but referenced directly so the
         ViewModel's device types are unambiguously compile-visible. -->
    <ProjectReference Include="..\..\src\Voxa.Audio.Onnx\Voxa.Audio.Onnx.csproj" />
    <!-- The shared LinearResampler (VTL-001) used by the device bridge (CaptureFormatConverter) and
         WavIo. Available transitively via the meta-package, but referenced directly since Studio uses
         the type directly (same convention as the ONNX device seam above). -->
    <ProjectReference Include="..\..\src\Voxa.Audio.Abstractions\Voxa.Audio.Abstractions.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- The window/taskbar icon, resolvable as /Assets/voxa.ico from XAML. -->
    <AvaloniaResource Include="Assets\voxa.ico" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="appsettings.json" CopyToOutputDirectory="PreserveNewest" />
    <!-- The bundled STT fixture (§6.1): replayable, known content, ships in-repo. -->
    <Content Include="fixtures\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Voxa.Studio.Tests" />
  </ItemGroup>

</Project>
