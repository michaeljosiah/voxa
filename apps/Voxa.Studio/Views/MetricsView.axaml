<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Voxa.Studio.ViewModels"
             xmlns:controls="using:Voxa.Studio.Controls"
             xmlns:services="using:Voxa.Studio.Services"
             x:Class="Voxa.Studio.Views.MetricsView"
             x:DataType="vm:MetricsViewModel">

  <Grid RowDefinitions="Auto,Auto,*,Auto">

    <!-- ── view bar ── -->
    <Border Grid.Row="0" Classes="vx-viewbar">
      <StackPanel Spacing="4">
        <TextBlock Classes="vx-h1" Text="Metrics" />
        <TextBlock Classes="vx-label"
                   Text="RUNS ARE EVIDENCE · SAME INPUT, TWO CONFIGS, HONEST COMPARISON" />
      </StackPanel>
    </Border>

    <!-- ── run strip: source · per-source controls · run / live header (§9.1) ── -->
    <Border Grid.Row="1" Classes="vx-card" Margin="20,16,20,0" Padding="14">
      <StackPanel Spacing="10">
        <Grid ColumnDefinitions="Auto,*,Auto">

          <Border Grid.Column="0" Classes="vx-seg-track" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
              <RadioButton x:Name="SrcScripted" Classes="vx-seg" GroupName="run-src" Content="Scripted deck"
                           IsChecked="{Binding IsScriptedSource, Mode=OneWay}" IsCheckedChanged="OnSourceChanged" />
              <RadioButton x:Name="SrcWav" Classes="vx-seg" GroupName="run-src" Content="Single WAV"
                           IsChecked="{Binding IsWavSource, Mode=OneWay}" IsCheckedChanged="OnSourceChanged" />
              <RadioButton x:Name="SrcMic" Classes="vx-seg" GroupName="run-src" Content="Live mic"
                           IsChecked="{Binding IsMicSource, Mode=OneWay}" IsCheckedChanged="OnSourceChanged" />
            </StackPanel>
          </Border>

          <!-- the compact live header: the heavy charts wait for completion -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="16" Margin="18,0"
                      VerticalAlignment="Center" IsVisible="{Binding IsRunning}">
            <TextBlock Classes="vx-mono" FontSize="12" Foreground="{StaticResource VxAccent2Brush}"
                       Text="{Binding ElapsedText}" />
            <TextBlock Classes="vx-mono vx-muted" FontSize="12"
                       Text="{Binding TurnCount, StringFormat='turns {0}'}" />
            <TextBlock Classes="vx-mono vx-muted" FontSize="12"
                       Text="{Binding LastTtfbText, StringFormat='last ttfb {0}'}" />
            <TextBlock Classes="vx-mono vx-muted" FontSize="12"
                       Text="{Binding RunErrorCount, StringFormat='errors {0}'}" />
          </StackPanel>

          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
            <Button Classes="vx-danger" Content="■ Stop"
                    IsVisible="{Binding IsRunning}" Command="{Binding StopCommand}" />
            <Button Classes="vx-primary" Content="▶ Run"
                    IsVisible="{Binding !IsRunning}" Command="{Binding RunCommand}" />
          </StackPanel>
        </Grid>

        <!-- per-source second line -->
        <StackPanel Orientation="Horizontal" Spacing="10" IsVisible="{Binding IsScriptedSource}">
          <TextBlock Classes="vx-mono vx-muted" FontSize="11" VerticalAlignment="Center"
                     Text="{Binding ScriptSummaryText}" />
          <Button Classes="vx-ghost" Content="Add WAVs…" Click="OnAddScriptFilesClicked" />
          <Button Classes="vx-ghost" Content="+ fixture" Command="{Binding AddFixtureToScriptCommand}"
                  ToolTip.Tip="Adds the bundled jfk.wav (11 s, known content)" />
          <Button Classes="vx-ghost" Content="Clear" Command="{Binding ClearScriptCommand}"
                  IsVisible="{Binding !!ScriptFiles.Count}" />
          <TextBlock Classes="vx-sub" VerticalAlignment="Center" Text="gap" Margin="8,0,0,0" />
          <Slider Width="140" Minimum="500" Maximum="5000" TickFrequency="100" IsSnapToTickEnabled="True"
                  VerticalAlignment="Center" Value="{Binding GapMs}" />
          <TextBlock Classes="vx-mono vx-muted" FontSize="11" VerticalAlignment="Center"
                     Text="{Binding GapText}" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Spacing="8" IsVisible="{Binding IsWavSource}">
          <TextBox Width="420" Text="{Binding WavPath}"
                   Watermark="Path to an utterance WAV — replayed once, run ends itself." />
          <Button Classes="vx-ghost" Content="Browse…" Click="OnBrowseWavClicked" />
        </StackPanel>

        <TextBlock Classes="vx-sub" IsVisible="{Binding IsMicSource}"
                   Text="Records the live pipeline from the default microphone — Stop ends the run. For honest comparisons, prefer the same scripted deck." />
      </StackPanel>
    </Border>

    <!-- ── workbench: charts | run list + compare (§9.2) ── -->
    <Grid Grid.Column="0" Grid.Row="2" ColumnDefinitions="*,330" Margin="20,14,20,0">

      <ScrollViewer Grid.Column="0" Margin="0,0,14,0">
        <StackPanel Spacing="14">

          <TextBlock Classes="vx-sub" TextWrapping="Wrap" IsVisible="{Binding !HasRuns}"
                     Text="No runs yet. Add the fixture to the scripted deck and press Run — the local pipeline replays it and every stage gets measured, keyless." />

          <!-- percentile card -->
          <Border Classes="vx-card" Padding="16" IsVisible="{Binding HasSelection}">
            <StackPanel Spacing="8">
              <TextBlock Classes="vx-label vx-accent" Text="VOICE-TO-VOICE TTFB" />
              <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBlock Classes="vx-mono" FontSize="38" FontWeight="Medium"
                           Foreground="{StaticResource VxTextBrush}" Text="{Binding P50Text}" />
                <TextBlock Classes="vx-mono vx-muted" FontSize="14" Text="ms p50"
                           VerticalAlignment="Bottom" Margin="0,0,0,7" />
                <StackPanel VerticalAlignment="Bottom" Margin="10,0,0,5" Spacing="2">
                  <TextBlock Classes="vx-mono vx-muted" FontSize="11" Text="{Binding P95Text}" />
                  <TextBlock Classes="vx-mono vx-muted" FontSize="11" Text="{Binding MaxText}" />
                </StackPanel>
                <TextBlock Classes="vx-mono vx-muted" FontSize="11" Text="{Binding RtfText}"
                           VerticalAlignment="Bottom" Margin="10,0,0,7" />
              </StackPanel>
              <StackPanel Orientation="Horizontal"
                          IsVisible="{Binding DeltaText, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBlock Classes="vx-mono" FontSize="12" Text="{Binding DeltaText}"
                           Foreground="{StaticResource VxGoodBrush}" IsVisible="{Binding DeltaImproved}" />
                <TextBlock Classes="vx-mono" FontSize="12" Text="{Binding DeltaText}"
                           Foreground="{StaticResource VxWarnBrush}" IsVisible="{Binding !DeltaImproved}" />
              </StackPanel>
              <TextBlock Classes="vx-sub" TextWrapping="Wrap" Text="{Binding TakeawayText}"
                         Foreground="{StaticResource VxAccent2Brush}" />
            </StackPanel>
          </Border>

          <!-- per-turn stage stacks -->
          <Border Classes="vx-card" Padding="16" IsVisible="{Binding HasSelection}">
            <StackPanel Spacing="10">
              <TextBlock Classes="vx-label" Text="STAGE BREAKDOWN PER TURN (MS)" />
              <controls:RunStacksControl Height="170" Turns="{Binding SelectedTurns}" />
              <StackPanel Orientation="Horizontal" Spacing="12">
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <Border Width="8" Height="8" CornerRadius="2" Background="#76849B" VerticalAlignment="Center" />
                  <TextBlock Classes="vx-sub" FontSize="11" Text="vad" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <Border Width="8" Height="8" CornerRadius="2" Background="#4FC3F7" VerticalAlignment="Center" />
                  <TextBlock Classes="vx-sub" FontSize="11" Text="stt" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <Border Width="8" Height="8" CornerRadius="2" Background="#CE93D8" VerticalAlignment="Center" />
                  <TextBlock Classes="vx-sub" FontSize="11" Text="agent" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <Border Width="8" Height="8" CornerRadius="2" Background="#FFB74D" VerticalAlignment="Center" />
                  <TextBlock Classes="vx-sub" FontSize="11" Text="tts" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" Spacing="5">
                  <Border Width="8" Height="8" CornerRadius="2" Background="#66BB6A" VerticalAlignment="Center" />
                  <TextBlock Classes="vx-sub" FontSize="11" Text="out" />
                </StackPanel>
              </StackPanel>
            </StackPanel>
          </Border>

          <!-- per-stage trend -->
          <Border Classes="vx-card" Padding="16" IsVisible="{Binding HasSelection}">
            <StackPanel Spacing="10">
              <TextBlock Classes="vx-label" Text="PER-STAGE TREND OVER THE RUN" />
              <controls:StageTrendControl Height="150" Turns="{Binding SelectedTurns}"
                                          FocusedStage="{Binding FocusedStage}" />
            </StackPanel>
          </Border>

          <TextBlock Classes="vx-mono vx-muted" FontSize="11" Text="{Binding MetaText}"
                     IsVisible="{Binding HasSelection}" Margin="2,0,0,8" />
        </StackPanel>
      </ScrollViewer>

      <!-- run list + compare -->
      <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto,Auto" Margin="0,0,0,8">
          <TextBlock Grid.Column="0" Classes="vx-label" Text="RUNS" VerticalAlignment="Center" />
          <Button Grid.Column="1" Classes="vx-ghost" Content="⤓ csv" FontSize="11" Padding="8,4"
                  Command="{Binding ExportCsvCommand}" ToolTip.Tip="Per-turn stage CSV next to the bundle" />
          <Button Grid.Column="2" Classes="vx-ghost" Content="folder" FontSize="11" Padding="8,4"
                  Command="{Binding RevealRunsFolderCommand}" ToolTip.Tip="Open the run-bundle folder" />
          <Button Grid.Column="3" Classes="vx-ghost" Content="✕" FontSize="11" Padding="8,4"
                  Command="{Binding DeleteSelectedRunCommand}" ToolTip.Tip="Delete the selected run" />
        </Grid>

        <ListBox Grid.Row="1" ItemsSource="{Binding Runs}" SelectedItem="{Binding SelectedRun}"
                 Background="Transparent">
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="vm:RunRowVm">
              <Grid ColumnDefinitions="Auto,*,Auto" Margin="2,2">
                <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}" Margin="0,0,8,0"
                          ToolTip.Tip="Check two runs to compare" />
                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                  <TextBlock Classes="vx-mono" FontSize="12" Text="{Binding Title}" />
                  <TextBlock Classes="vx-sub" FontSize="10" Text="{Binding Sub}" />
                </StackPanel>
                <TextBlock Grid.Column="2" Classes="vx-mono" FontSize="12" VerticalAlignment="Center"
                           Foreground="{StaticResource VxAccent2Brush}" Text="{Binding P50Text}" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <!-- compare pane (exactly two runs checked) -->
        <Border Grid.Row="2" Classes="vx-card" Padding="14" Margin="0,10,0,0"
                IsVisible="{Binding Compare, Converter={x:Static ObjectConverters.IsNotNull}}">
          <StackPanel Spacing="8">
            <TextBlock Classes="vx-label vx-accent" Text="⇄ COMPARE" />
            <TextBlock Classes="vx-mono" FontSize="12" TextWrapping="Wrap"
                       Text="{Binding Compare.Headline, FallbackValue=''}" />
            <ItemsControl ItemsSource="{Binding Compare.Rows, FallbackValue={x:Null}}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="services:CompareRow">
                  <Grid ColumnDefinitions="86,*" Margin="0,1">
                    <TextBlock Grid.Column="0" Classes="vx-mono vx-muted" FontSize="11" Text="{Binding Label}" />
                    <StackPanel Grid.Column="1">
                      <TextBlock Classes="vx-mono" FontSize="11" Text="{Binding DeltaText}"
                                 Foreground="{StaticResource VxGoodBrush}" IsVisible="{Binding Improved}" />
                      <TextBlock Classes="vx-mono" FontSize="11" Text="{Binding DeltaText}"
                                 Foreground="{StaticResource VxWarnBrush}" IsVisible="{Binding !Improved}" />
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
            <ItemsControl ItemsSource="{Binding Compare.Warnings, FallbackValue={x:Null}}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                  <TextBlock Classes="vx-sub" FontSize="11" TextWrapping="Wrap" Text="{Binding}"
                             Foreground="{StaticResource VxWarnBrush}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>
      </Grid>
    </Grid>

    <!-- ── status ── -->
    <StackPanel Grid.Row="3" Spacing="4" Margin="20,10,20,14">
      <TextBlock Classes="vx-sub" Text="{Binding StatusText}" />
      <TextBlock Foreground="{StaticResource VxBadBrush}" FontSize="12" TextWrapping="Wrap"
                 Text="{Binding ErrorText}"
                 IsVisible="{Binding ErrorText, Converter={x:Static ObjectConverters.IsNotNull}}" />
    </StackPanel>

  </Grid>
</UserControl>
