<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Voxa.Studio.ViewModels"
        xmlns:views="using:Voxa.Studio.Views"
        x:Class="Voxa.Studio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Voxa Studio"
        Width="1280" Height="820"
        MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="42"
        Background="{StaticResource VxBgBrush}">

  <Grid ColumnDefinitions="64,*" RowDefinitions="42,*">

    <!-- ── title bar: wordmark + live dot; whole strip is a drag area ── -->
    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
            IsHitTestVisible="False">
      <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0" Spacing="10">
        <Path Width="14" Height="14" Stretch="Uniform"
              Fill="{StaticResource VxAccentBrush}"
              Data="M2,2 L12,2 L22,22 L12,22 Z" />
        <TextBlock Text="VOXA" FontSize="13" FontWeight="Bold" LetterSpacing="3"
                   Foreground="#FFFFFF" VerticalAlignment="Center" />
        <TextBlock Text="STUDIO" FontSize="13" FontWeight="Light" LetterSpacing="3"
                   Foreground="{StaticResource VxMutedBrush}" VerticalAlignment="Center" />
        <Ellipse Classes="vx-dot" Margin="6,1,0,0"
                 Fill="{StaticResource VxGoodBrush}"
                 IsVisible="{Binding IsLive}" />
      </StackPanel>
    </Border>

    <!-- ── nav rail ── -->
    <Border Grid.Row="1" Grid.Column="0"
            BorderBrush="{StaticResource VxBorderBrush}" BorderThickness="0,0,1,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" HorizontalAlignment="Center" Margin="0,10,0,0">

          <RadioButton x:Name="NavTalk" Classes="vx-nav" GroupName="nav" Tag="Talk"
                       IsChecked="True" IsCheckedChanged="OnNavChanged">
            <PathIcon Data="M12,14 A3,3 0 0 0 15,11 L15,5 A3,3 0 0 0 9,5 L9,11 A3,3 0 0 0 12,14 Z M17,11 A5,5 0 0 1 7,11 L5,11 A7,7 0 0 0 11,17.92 L11,21 L13,21 L13,17.92 A7,7 0 0 0 19,11 Z" />
          </RadioButton>

          <RadioButton x:Name="NavVoices" Classes="vx-nav" GroupName="nav" Tag="Voices"
                       IsCheckedChanged="OnNavChanged">
            <PathIcon Data="M3,10 L3,14 L5,14 L5,10 Z M7,6 L7,18 L9,18 L9,6 Z M11,3 L11,21 L13,21 L13,3 Z M15,8 L15,16 L17,16 L17,8 Z M19,10 L19,14 L21,14 L21,10 Z" />
          </RadioButton>

          <RadioButton x:Name="NavModels" Classes="vx-nav" GroupName="nav" Tag="Models"
                       IsCheckedChanged="OnNavChanged">
            <PathIcon Data="M12,3 C7.58,3 4,4.79 4,7 L4,17 C4,19.21 7.58,21 12,21 C16.42,21 20,19.21 20,17 L20,7 C20,4.79 16.42,3 12,3 Z M12,5 C15.87,5 18,6.5 18,7 C18,7.5 15.87,9 12,9 C8.13,9 6,7.5 6,7 C6,6.5 8.13,5 12,5 Z M18,17 C18,17.5 15.87,19 12,19 C8.13,19 6,17.5 6,17 L6,14.77 C7.61,15.55 9.72,16 12,16 C14.28,16 16.39,15.55 18,14.77 Z M18,12 C18,12.5 15.87,14 12,14 C8.13,14 6,12.5 6,12 L6,9.77 C7.61,10.55 9.72,11 12,11 C14.28,11 16.39,10.55 18,9.77 Z" />
          </RadioButton>

          <RadioButton x:Name="NavConfig" Classes="vx-nav" GroupName="nav" Tag="Config"
                       IsCheckedChanged="OnNavChanged">
            <PathIcon Data="M3,17 L3,19 L9,19 L9,17 Z M3,5 L3,7 L13,7 L13,5 Z M13,21 L13,19 L21,19 L21,17 L13,17 L13,15 L11,15 L11,21 Z M7,9 L7,11 L3,11 L3,13 L7,13 L7,15 L9,15 L9,9 Z M21,13 L21,11 L11,11 L11,13 Z M15,9 L17,9 L17,7 L21,7 L21,5 L17,5 L17,3 L15,3 Z" />
          </RadioButton>

        </StackPanel>
      </DockPanel>
    </Border>

    <!-- ── content host: code-behind swaps the active view ── -->
    <Panel Grid.Row="1" Grid.Column="1">
      <views:TalkView x:Name="TalkHost" DataContext="{Binding Talk}" />
      <views:VoicesView x:Name="VoicesHost" DataContext="{Binding Voices}" IsVisible="False" />
      <views:ModelsView x:Name="ModelsHost" DataContext="{Binding Models}" IsVisible="False" />
      <views:ConfigView x:Name="ConfigHost" DataContext="{Binding Config}" IsVisible="False" />
    </Panel>

  </Grid>
</Window>
