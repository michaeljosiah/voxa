<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:Voxa.Studio.ViewModels"
        xmlns:views="using:Voxa.Studio.Views"
        xmlns:controls="using:Voxa.Studio.Controls"
        x:Class="Voxa.Studio.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Voxa Studio"
        Icon="/Assets/voxa.ico"
        Width="1280" Height="820"
        MinWidth="960" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="44"
        Background="{StaticResource VxBgBrush}">

  <Window.Styles>
    <!-- The settings gear is a plain Button (it opens a dialog, not a nav section), styled to sit
         quietly at the foot of the rail: muted glyph that brightens on hover, like the nav icons. -->
    <Style Selector="Button#NavSettings">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Height" Value="52" />
    </Style>
    <Style Selector="Button#NavSettings PathIcon">
      <Setter Property="Foreground" Value="{StaticResource VxMutedBrush}" />
      <Setter Property="Width" Value="17" />
      <Setter Property="Height" Value="17" />
    </Style>
    <Style Selector="Button#NavSettings:pointerover PathIcon">
      <Setter Property="Foreground" Value="{StaticResource VxTextBrush}" />
    </Style>

    <!-- replay-launch: muted glyph that warms to the accent on hover -->
    <Style Selector="Button#ReplaySplash">
      <Setter Property="CornerRadius" Value="6" />
    </Style>
    <Style Selector="Button#ReplaySplash:pointerover PathIcon">
      <Setter Property="Foreground" Value="{StaticResource VxAccentBrush}" />
    </Style>
    <Style Selector="Button#ReplaySplash:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
  </Window.Styles>

  <Grid ColumnDefinitions="82,*" RowDefinitions="44,*">

    <!-- ── titlebar: the mark lands here from the splash · wordmark · live status ── -->
    <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
            Background="{StaticResource VxPanelBrush}"
            BorderBrush="{StaticResource VxLine1Brush}"
            BorderThickness="0,0,0,1"
            IsHitTestVisible="False">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="14,0,140,0">
        <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
          <controls:VoxaMarkControl Width="18" Height="18"
                                    Glow="{Binding IsLive}" />
          <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
            <TextBlock Text="VOXA" FontSize="12" FontWeight="Bold" LetterSpacing="3.4"
                       Foreground="{StaticResource VxTextBrush}" />
            <TextBlock Text="STUDIO" FontSize="12" FontWeight="Normal" LetterSpacing="3.4"
                       Foreground="{StaticResource VxMutedBrush}" />
          </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                    Spacing="7" IsVisible="{Binding IsLive}">
          <Ellipse Classes="vx-dot vx-live" />
          <TextBlock x:Name="SessionClock" Classes="vx-mono" FontSize="11"
                     Foreground="{StaticResource VxAccent2Brush}" Text="00:00" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- replay-launch button: a hit-testable sibling of the (non-interactive, draggable) titlebar,
         sitting just left of the native caption buttons. Re-shows the splash for the brand moment. -->
    <Button Grid.Row="0" Grid.Column="1" x:Name="ReplaySplash" Click="OnReplaySplashClick"
            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,146,0"
            Background="Transparent" BorderThickness="0" Width="30" Height="30" Padding="0"
            ToolTip.Tip="Replay launch">
      <PathIcon x:Name="ReplaySplashIcon" Width="15" Height="15" Foreground="{StaticResource VxMutedBrush}"
                Data="M12,2 L13.4,8.6 L20,10 L13.4,11.4 L12,18 L10.6,11.4 L4,10 L10.6,8.6 Z M18.5,3 L19.1,5.4 L21.5,6 L19.1,6.6 L18.5,9 L17.9,6.6 L15.5,6 L17.9,5.4 Z" />
    </Button>

    <!-- ── nav rail: icon + label, active gets the edge bar ── -->
    <Border Grid.Row="1" Grid.Column="0"
            Background="{StaticResource VxPanelBrush}"
            BorderBrush="{StaticResource VxLine1Brush}" BorderThickness="0,0,1,0">
      <DockPanel>

      <!-- account chip at the very foot of the rail (the reference's avatar) -->
      <Border x:Name="NavAvatar" DockPanel.Dock="Bottom" Width="28" Height="28" Margin="0,4,0,12"
              CornerRadius="14" HorizontalAlignment="Center"
              Background="{StaticResource VxRaisedBrush}"
              BorderBrush="{StaticResource VxLine2Brush}" BorderThickness="1">
        <TextBlock x:Name="NavAvatarText" Text="VX" HorizontalAlignment="Center" VerticalAlignment="Center"
                   FontFamily="{StaticResource VxMono}" FontSize="11"
                   Foreground="{StaticResource VxText2Brush}" />
      </Border>

      <!-- settings gear pinned to the foot of the rail — opens the dialog, not a section -->
      <Button x:Name="NavSettings" DockPanel.Dock="Bottom" Click="OnSettingsClick" Margin="0,0,0,8"
              ToolTip.Tip="Settings — providers and credentials">
        <PathIcon Data="M19.14,12.94 C19.18,12.64 19.2,12.33 19.2,12 C19.2,11.68 19.18,11.36 19.13,11.06 L21.16,9.48 C21.34,9.34 21.39,9.07 21.28,8.87 L19.36,5.55 C19.24,5.33 18.99,5.26 18.77,5.33 L16.38,6.29 C15.88,5.91 15.35,5.59 14.76,5.35 L14.4,2.81 C14.36,2.57 14.16,2.4 13.92,2.4 L10.08,2.4 C9.84,2.4 9.65,2.57 9.61,2.81 L9.25,5.35 C8.66,5.59 8.12,5.92 7.63,6.29 L5.24,5.33 C5.02,5.25 4.77,5.33 4.65,5.55 L2.74,8.87 C2.62,9.08 2.66,9.34 2.86,9.48 L4.89,11.06 C4.84,11.36 4.8,11.69 4.8,12 C4.8,12.31 4.82,12.64 4.87,12.94 L2.84,14.52 C2.66,14.66 2.61,14.93 2.72,15.13 L4.64,18.45 C4.76,18.67 5.01,18.74 5.23,18.67 L7.62,17.71 C8.12,18.09 8.65,18.41 9.24,18.65 L9.6,21.19 C9.65,21.43 9.84,21.6 10.08,21.6 L13.92,21.6 C14.16,21.6 14.36,21.43 14.39,21.19 L14.75,18.65 C15.34,18.41 15.88,18.09 16.37,17.71 L18.76,18.67 C18.98,18.75 19.23,18.67 19.35,18.45 L21.27,15.13 C21.39,14.91 21.34,14.66 21.15,14.52 L19.14,12.94 Z M12,15.6 C10.02,15.6 8.4,13.98 8.4,12 C8.4,10.02 10.02,8.4 12,8.4 C13.98,8.4 15.6,10.02 15.6,12 C15.6,13.98 13.98,15.6 12,15.6 Z" />
      </Button>

      <StackPanel Margin="0,8,0,0">

        <RadioButton x:Name="NavTalk" Classes="vx-nav" GroupName="nav" Tag="Talk"
                     IsChecked="True" IsCheckedChanged="OnNavChanged">
          <PathIcon Data="M12,14 A3,3 0 0 0 15,11 L15,5 A3,3 0 0 0 9,5 L9,11 A3,3 0 0 0 12,14 Z M17,11 A5,5 0 0 1 7,11 L5,11 A7,7 0 0 0 11,17.92 L11,21 L13,21 L13,17.92 A7,7 0 0 0 19,11 Z" />
        </RadioButton>

        <!-- flask-conical, the kit's Playgrounds glyph (outline via even-odd cutout) -->
        <RadioButton x:Name="NavPlaygrounds" Classes="vx-nav" GroupName="nav" Tag="Playgrounds"
                     IsCheckedChanged="OnNavChanged">
          <PathIcon Data="M9,2 L15,2 L15,4 L14,4 L14,8.55 L19.6,18.6 A2.6,2.6 0 0 1 17.3,22.5 L6.7,22.5 A2.6,2.6 0 0 1 4.4,18.6 L10,8.55 L10,4 L9,4 Z M11.5,4.6 L12.5,4.6 L12.5,9 L17.8,18.7 A1.2,1.2 0 0 1 16.9,20.6 L7.1,20.6 A1.2,1.2 0 0 1 6.2,18.7 L11.5,9 Z" />
        </RadioButton>

        <!-- waveform/voice glyph for the Voices library -->
        <RadioButton x:Name="NavVoices" Classes="vx-nav" GroupName="nav" Tag="Voices"
                     IsCheckedChanged="OnNavChanged">
          <PathIcon Data="M11,3 L13,3 L13,21 L11,21 Z M7,7 L9,7 L9,17 L7,17 Z M15,7 L17,7 L17,17 L15,17 Z M3,10 L5,10 L5,14 L3,14 Z M19,10 L21,10 L21,14 L19,14 Z" />
        </RadioButton>

        <!-- hexagon, the kit's Builder glyph (outline via even-odd cutout) -->
        <RadioButton x:Name="NavBuilder" Classes="vx-nav" GroupName="nav" Tag="Builder"
                     IsCheckedChanged="OnNavChanged">
          <PathIcon Data="M12,2.6 L20.2,7.3 L20.2,16.7 L12,21.4 L3.8,16.7 L3.8,7.3 Z M12,4.9 L5.8,8.45 L5.8,15.55 L12,19.1 L18.2,15.55 L18.2,8.45 Z" />
        </RadioButton>

        <!-- bar chart, the kit's Metrics glyph -->
        <RadioButton x:Name="NavMetrics" Classes="vx-nav" GroupName="nav" Tag="Metrics"
                     IsCheckedChanged="OnNavChanged">
          <PathIcon Data="M4,20 L4,12 L7,12 L7,20 Z M10.5,20 L10.5,4 L13.5,4 L13.5,20 Z M17,20 L17,9 L20,9 L20,20 Z M3,21.5 L21,21.5 L21,20.3 L3,20.3 Z" />
        </RadioButton>

        <RadioButton x:Name="NavModels" Classes="vx-nav" GroupName="nav" Tag="Models"
                     IsCheckedChanged="OnNavChanged">
          <PathIcon Data="M12,3 C7.58,3 4,4.79 4,7 L4,17 C4,19.21 7.58,21 12,21 C16.42,21 20,19.21 20,17 L20,7 C20,4.79 16.42,3 12,3 Z M12,5 C15.87,5 18,6.5 18,7 C18,7.5 15.87,9 12,9 C8.13,9 6,7.5 6,7 C6,6.5 8.13,5 12,5 Z M18,17 C18,17.5 15.87,19 12,19 C8.13,19 6,17.5 6,17 L6,14.77 C7.61,15.55 9.72,16 12,16 C14.28,16 16.39,15.55 18,14.77 Z M18,12 C18,12.5 15.87,14 12,14 C8.13,14 6,12.5 6,12 L6,9.77 C7.61,10.55 9.72,11 12,11 C14.28,11 16.39,10.55 18,9.77 Z" />
        </RadioButton>

        <!-- Config before Diarization, matching the reference rail order (Tag drives the section
             index, so the swap is purely visual). -->
        <RadioButton x:Name="NavConfig" Classes="vx-nav" GroupName="nav" Tag="Config"
                     IsCheckedChanged="OnNavChanged">
          <PathIcon Data="M3,17 L3,19 L9,19 L9,17 Z M3,5 L3,7 L13,7 L13,5 Z M13,21 L13,19 L21,19 L21,17 L13,17 L13,15 L11,15 L11,21 Z M7,9 L7,11 L3,11 L3,13 L7,13 L7,15 L9,15 L9,9 Z M21,13 L21,11 L11,11 L11,13 Z M15,9 L17,9 L17,7 L21,7 L21,5 L17,5 L17,3 L15,3 Z" />
        </RadioButton>

        <!-- stacked time-bars: the Diarization (speech-segmentation) analytics view -->
        <RadioButton x:Name="NavDiarization" Classes="vx-nav" GroupName="nav" Tag="Diarization"
                     IsCheckedChanged="OnNavChanged">
          <PathIcon Data="M3,5 L11,5 L11,7 L3,7 Z M13,5 L21,5 L21,7 L13,7 Z M7,11 L17,11 L17,13 L7,13 Z M3,17 L9,17 L9,19 L3,19 Z M11,17 L21,17 L21,19 L11,19 Z" />
        </RadioButton>

      </StackPanel>
      </DockPanel>
    </Border>

    <!-- ── content area: app-wide pipeline-profile bar + the swappable view host ── -->
    <Grid Grid.Row="1" Grid.Column="1" RowDefinitions="Auto,*">

      <!-- pipeline profile bar — on every page; switching the active profile applies it everywhere.
           Disabled while a session is live (a container rebuild can't run under it, like Config Apply). -->
      <Border Grid.Row="0" Background="{StaticResource VxPanelBrush}"
              BorderBrush="{StaticResource VxLine1Brush}" BorderThickness="0,0,0,1"
              Padding="20,9" MinHeight="52" IsEnabled="{Binding !IsLive}">
        <Grid ColumnDefinitions="Auto,Auto,*,Auto">
          <TextBlock Grid.Column="0" Classes="vx-label vx-accent" Text="PIPELINE PROFILE"
                     VerticalAlignment="Center" Margin="0,0,12,0" />
          <ComboBox Grid.Column="1" MinWidth="220" VerticalAlignment="Center"
                    ItemsSource="{Binding PipelineProfiles}"
                    SelectedItem="{Binding SelectedPipelineProfile}"
                    ToolTip.Tip="The active pipeline — switching applies it everywhere (Talk, Playgrounds, …)" />

          <!-- the active chain as stage chips (dot + name · chevron); else the build-hint -->
          <ItemsControl Grid.Column="2" Margin="14,0,0,0" VerticalAlignment="Center"
                        ItemsSource="{Binding ActiveChain}" IsVisible="{Binding HasActiveChain}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate><StackPanel Orientation="Horizontal" /></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:ShellChainNode">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                  <Border CornerRadius="999" Padding="9,3" Background="{StaticResource VxPanel2Brush}"
                          BorderBrush="{StaticResource VxLine1Brush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                      <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                               Fill="{Binding Stage, Converter={x:Static views:Converters.StageBrush}}" />
                      <TextBlock Text="{Binding Name}" FontFamily="{StaticResource VxMono}" FontSize="10.5"
                                 Foreground="{StaticResource VxText2Brush}" VerticalAlignment="Center" />
                    </StackPanel>
                  </Border>
                  <Path Data="M0,0 L4,4 L0,8" Stroke="{StaticResource VxMutedBrush}" StrokeThickness="1.3"
                        Margin="7,0" VerticalAlignment="Center" IsVisible="{Binding ShowSeparator}" />
                </StackPanel>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Grid.Column="2" Classes="vx-sub" FontSize="12.5" VerticalAlignment="Center" Margin="14,0,0,0"
                     Foreground="{StaticResource VxMutedBrush}"
                     Text="Build a pipeline in Builder, then “Save as profile” to add one here."
                     IsVisible="{Binding !HasActiveChain}" />

          <Button Grid.Column="3" Classes="vx-ghost" Content="Delete" Click="OnDeleteProfileClick"
                  VerticalAlignment="Center" ToolTip.Tip="Delete the selected profile"
                  IsVisible="{Binding HasPipelineProfiles}" />
        </Grid>
      </Border>

      <!-- content host: code-behind swaps the active view (+ toast layer, added at the window root) -->
      <Panel Grid.Row="1">
        <views:TalkView x:Name="TalkHost" DataContext="{Binding Talk}" />
        <views:PlaygroundsView x:Name="PlaygroundsHost" DataContext="{Binding Playgrounds}" IsVisible="False" />
        <views:VoicesView x:Name="VoicesHost" DataContext="{Binding Voices}" IsVisible="False" />
        <views:BuilderView x:Name="BuilderHost" DataContext="{Binding Builder}" IsVisible="False" />
        <views:MetricsView x:Name="MetricsHost" DataContext="{Binding Metrics}" IsVisible="False" />
        <views:ModelsView x:Name="ModelsHost" DataContext="{Binding Models}" IsVisible="False" />
        <views:ConfigView x:Name="ConfigHost" DataContext="{Binding Config}" IsVisible="False" />
        <views:DiarizationView x:Name="DiarizationHost" DataContext="{Binding Diarization}" IsVisible="False" />

        <!-- "Surface is busy" — shades a contended view while another holds the device + CPU (VST-005) -->
        <Border Background="#B8080B10" IsVisible="{Binding IsCurrentSectionBlocked}">
          <Border Width="420" MaxWidth="420" VerticalAlignment="Center" HorizontalAlignment="Center"
                  Padding="30,28" CornerRadius="20"
                  Background="{StaticResource VxPanel2Brush}"
                  BorderBrush="{StaticResource VxLine2Brush}" BorderThickness="1"
                  BoxShadow="0 16 48 0 #8C000000">
            <StackPanel Spacing="0" HorizontalAlignment="Center">
              <Border Width="46" Height="46" CornerRadius="10" Margin="0,0,0,16"
                      Background="{StaticResource VxWarnSoftBrush}">
                <PathIcon Width="22" Height="22" Foreground="{StaticResource VxWarnBrush}"
                          Data="M12,3 A4,4 0 0 0 8,7 L8,10 L7,10 A1,1 0 0 0 6,11 L6,20 A1,1 0 0 0 7,21 L17,21 A1,1 0 0 0 18,20 L18,11 A1,1 0 0 0 17,10 L16,10 L16,7 A4,4 0 0 0 12,3 Z M10,7 A2,2 0 0 1 14,7 L14,10 L10,10 Z" />
              </Border>
              <TextBlock Text="Surface is busy" FontSize="16" FontWeight="SemiBold"
                         HorizontalAlignment="Center" Foreground="{StaticResource VxTextBrush}" />
              <TextBlock Text="{Binding BlockedMessage}" TextWrapping="Wrap" TextAlignment="Center"
                         FontSize="13.5" Margin="0,9,0,0" Foreground="{StaticResource VxText2Brush}" />
              <StackPanel Orientation="Horizontal" Spacing="9" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button Classes="vx-secondary" Content="{Binding GoToOwnerLabel}"
                        Command="{Binding GoToBusyOwnerCommand}" />
                <Button Classes="vx-danger" Content="End session" Command="{Binding EndBusyOwnerCommand}" />
              </StackPanel>
            </StackPanel>
          </Border>
        </Border>
      </Panel>
    </Grid>

    <!-- toast layer: floats over the whole shell, bottom-right; empty areas pass clicks through -->
    <views:ToastHost Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2"
                     DataContext="{Binding Toasts}" />

  </Grid>
</Window>
