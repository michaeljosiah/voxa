<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Voxa.Studio.ViewModels"
             xmlns:controls="using:Voxa.Studio.Controls"
             xmlns:conv="using:Voxa.Studio.Views"
             x:Class="Voxa.Studio.Views.TalkView"
             x:DataType="vm:TalkViewModel">

  <UserControl.Styles>
    <!-- in-progress phases breathe; the colour + label carry the state if motion is reduced -->
    <Style Selector="Ellipse.pulse">
      <Style.Animations>
        <Animation Duration="0:0:1.3" IterationCount="INFINITE" Easing="SineEaseInOut">
          <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1" /></KeyFrame>
          <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.3" /></KeyFrame>
          <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- ── view bar: title + provider chain (data → mono) · devices · session control ── -->
    <Border Grid.Row="0" Classes="vx-viewbar">
      <Grid ColumnDefinitions="Auto,*,Auto">
        <StackPanel Grid.Column="0" Spacing="6" VerticalAlignment="Center">
          <TextBlock Classes="vx-h1" Text="Talk" />
          <!-- the live pipeline, always visible — "exactly what's running" -->
          <Border CornerRadius="6" Padding="8,3" HorizontalAlignment="Left"
                  Background="{StaticResource VxPanel2Brush}"
                  BorderBrush="{StaticResource VxLine1Brush}" BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Classes="vx-label vx-accent" Text="PIPELINE" VerticalAlignment="Center" />
              <TextBlock Classes="vx-mono" FontSize="11" VerticalAlignment="Center"
                         Foreground="{StaticResource VxText2Brush}" Text="{Binding ProviderChain}" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
          <ComboBox Width="210" ItemsSource="{Binding Microphones}"
                    SelectedItem="{Binding SelectedMicrophone}"
                    PlaceholderText="Microphone" />
          <ComboBox Width="210" ItemsSource="{Binding Speakers}"
                    SelectedItem="{Binding SelectedSpeaker}"
                    PlaceholderText="Speaker" />
          <Button Classes="vx-primary" Content="● Start session"
                  Command="{Binding StartCommand}"
                  IsVisible="{Binding !IsRunning}" />
          <Button Classes="vx-danger" Content="■ Stop"
                  Command="{Binding StopCommand}"
                  IsVisible="{Binding IsRunning}" />
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── body: transcript | trace + waterfall ── -->
    <Grid Grid.Row="1" ColumnDefinitions="5*,12,4*" Margin="20,16,20,0">

      <!-- transcript -->
      <Border Grid.Column="0" Classes="vx-card-flush">
        <Grid RowDefinitions="*,Auto">
          <!-- empty state teaches instead of leaving a void (P4) -->
          <TextBlock Grid.Row="0" Classes="vx-sub" HorizontalAlignment="Center" VerticalAlignment="Center"
                     IsVisible="{Binding !Transcript.Count}"
                     Text="Start a session and say something — the conversation lands here." />
          <ScrollViewer Grid.Row="0" x:Name="TranscriptScroll" Padding="16">
            <ItemsControl ItemsSource="{Binding Transcript}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="vm:ChatBubble">
                  <Border MaxWidth="520" Margin="0,4"
                          Padding="12,8" CornerRadius="10"
                          HorizontalAlignment="{Binding IsUser, Converter={x:Static conv:Converters.BubbleAlign}}"
                          Background="{Binding IsUser, Converter={x:Static conv:Converters.BubbleBrush}}">
                    <StackPanel Spacing="2">
                      <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                 Foreground="{StaticResource VxText2Brush}" />
                      <TextBlock Text="⊘ interrupted" FontSize="10"
                                 FontFamily="{StaticResource VxMono}"
                                 Foreground="{StaticResource VxWarnBrush}"
                                 IsVisible="{Binding IsInterrupted}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

          <!-- live pipeline state — the single, prominent "what's happening" cue (also tells you
               when the mic is actually live: Listening = your turn) -->
          <Border Grid.Row="1" Margin="16,8,16,12" Padding="13,7" CornerRadius="20"
                  HorizontalAlignment="Left" IsVisible="{Binding IsRunning}"
                  Background="{StaticResource VxPanel2Brush}"
                  BorderBrush="{StaticResource VxLine1Brush}" BorderThickness="1">
            <StackPanel Orientation="Horizontal" Spacing="9" VerticalAlignment="Center">
              <Ellipse Width="10" Height="10" VerticalAlignment="Center"
                       Classes.pulse="{Binding PhasePulse}"
                       Fill="{Binding Phase, Converter={x:Static conv:Converters.PhaseBrush}}" />
              <TextBlock FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"
                         Foreground="{Binding Phase, Converter={x:Static conv:Converters.PhaseBrush}}"
                         Text="{Binding PhaseLabel}" />
            </StackPanel>
          </Border>
        </Grid>
      </Border>

      <!-- trace + waterfalls + event log -->
      <Grid Grid.Column="2" RowDefinitions="Auto,170,12,Auto,*">
        <TextBlock Grid.Row="0" Classes="vx-label vx-accent" Text="VAD PROBABILITY" Margin="2,0,0,6" />
        <Border Grid.Row="1" Classes="vx-card-flush" Padding="8">
          <controls:VadTraceControl Samples="{Binding TraceSnapshot}"
                                    Threshold="{Binding VadThreshold}" />
        </Border>

        <!-- the heading appears with the first measured turn — no header over nothing -->
        <TextBlock Grid.Row="3" Classes="vx-label vx-accent" Text="TURN WATERFALL" Margin="2,12,0,6"
                   IsVisible="{Binding !!Waterfalls.Count}" />
        <Grid Grid.Row="4" RowDefinitions="Auto,*">
          <ItemsControl Grid.Row="0" ItemsSource="{Binding Waterfalls}" MaxHeight="220">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="vm:TurnWaterfall">
                <Grid ColumnDefinitions="*,Auto" Margin="0,3">
                  <controls:WaterfallControl Grid.Column="0" Height="30" Waterfall="{Binding}" />
                  <TextBlock Grid.Column="1" Classes="vx-mono" FontSize="11" Margin="10,0,0,0"
                             VerticalAlignment="Top" Text="{Binding TotalText}"
                             Foreground="{StaticResource VxTextBrush}" />
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <Grid Grid.Row="1" RowDefinitions="Auto,*" Margin="0,10,0,0">
            <CheckBox Grid.Row="0" Content="Event log" FontSize="11"
                      Foreground="{StaticResource VxMutedBrush}"
                      IsChecked="{Binding ShowEventLog}" />
            <Border Grid.Row="1" Classes="vx-card-flush" IsVisible="{Binding ShowEventLog}">
              <ListBox ItemsSource="{Binding EventLog}" FontSize="10"
                       FontFamily="{StaticResource VxMono}" />
            </Border>
          </Grid>
        </Grid>
      </Grid>
    </Grid>

    <!-- ── status strip ── -->
    <StackPanel Grid.Row="2" Spacing="4" Margin="20,10,20,14">
      <TextBlock Classes="vx-sub" Text="{Binding StatusText}" />
      <TextBlock Foreground="{StaticResource VxBadBrush}" FontSize="12" TextWrapping="Wrap"
                 Text="{Binding ErrorText}" IsVisible="{Binding ErrorText, Converter={x:Static ObjectConverters.IsNotNull}}" />
    </StackPanel>

  </Grid>
</UserControl>
