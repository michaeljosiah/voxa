<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Voxa.Studio.Controls">

  <!-- ════════ VOXA Studio stylesheet (VST-002; VST-005 rebrand warm→cool) ════════
       Dark, calm, one accent: cool blue-grey surfaces, cool hairlines, a single Pulse
       cyan doing the talking (Voxa). Radii from the brief token scale: 6 badges/inline
       chips · 10 controls (buttons, inputs) · 14 cards/panels · 20 modals/hero · 999 pills.
       Motion tokens (Theme/Motion.cs): fast 120 · standard 240 · draw 1100 · pulse 2600;
       XAML transitions hardcode the same values. Text on cyan is page ink.
       If a screen looks exciting while idle, it's wrong. -->

  <Style Selector="Window">
    <Setter Property="Background" Value="{StaticResource VxBgBrush}" />
    <Setter Property="FontFamily" Value="{StaticResource VxUi}" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Foreground" Value="{StaticResource VxTextBrush}" />
  </Style>

  <!-- ── typography ─────────────────────────────────────────────────────── -->

  <!-- Card / section heading: 16 semibold, tight tracking. -->
  <Style Selector="TextBlock.vx-h1">
    <Setter Property="FontSize" Value="16" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LetterSpacing" Value="-0.2" />
    <Setter Property="Foreground" Value="{StaticResource VxTextBrush}" />
  </Style>

  <!-- The ViewBar title (every view's header): 18 bold, tight tracking — the brief's view-title size. -->
  <Style Selector="TextBlock.vx-viewtitle">
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="LetterSpacing" Value="-0.2" />
    <Setter Property="Foreground" Value="{StaticResource VxTextBrush}" />
  </Style>

  <Style Selector="TextBlock.vx-sub">
    <Setter Property="FontSize" Value="12" />
    <Setter Property="Foreground" Value="{StaticResource VxMutedBrush}" />
  </Style>

  <Style Selector="TextBlock.vx-muted">
    <Setter Property="Foreground" Value="{StaticResource VxMutedBrush}" />
  </Style>

  <Style Selector="TextBlock.vx-body">
    <Setter Property="Foreground" Value="{StaticResource VxText2Brush}" />
  </Style>

  <Style Selector="TextBlock.vx-mono">
    <Setter Property="FontFamily" Value="{StaticResource VxMono}" />
  </Style>

  <!-- Mono micro-label: UPPERCASE text supplied by the view ("if it's data, it's mono"). -->
  <Style Selector="TextBlock.vx-label">
    <Setter Property="FontFamily" Value="{StaticResource VxMono}" />
    <Setter Property="FontSize" Value="10" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="LetterSpacing" Value="0.8" />
    <Setter Property="Foreground" Value="{StaticResource VxMutedBrush}" />
  </Style>

  <!-- Section-head variant: the lighter cyan is reserved for these. -->
  <Style Selector="TextBlock.vx-label.vx-accent">
    <Setter Property="Foreground" Value="{StaticResource VxAccent2Brush}" />
  </Style>

  <!-- ── surfaces ───────────────────────────────────────────────────────── -->

  <Style Selector="Border.vx-card">
    <Setter Property="Background" Value="{StaticResource VxPanel2Brush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine1Brush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Padding" Value="14" />
    <Setter Property="BoxShadow" Value="0 1 2 0 #33000000" />
  </Style>

  <Style Selector="Border.vx-card-flush">
    <Setter Property="Background" Value="{StaticResource VxPanel2Brush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine1Brush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="BoxShadow" Value="0 1 2 0 #33000000" />
  </Style>

  <Style Selector="Border.vx-chip">
    <Setter Property="Background" Value="{StaticResource VxRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine2Brush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="10,3" />
  </Style>

  <!-- The shared view header strip (the kit's ViewBar). -->
  <Style Selector="Border.vx-viewbar">
    <Setter Property="Background" Value="{StaticResource VxPanelBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine1Brush}" />
    <Setter Property="BorderThickness" Value="0,0,0,1" />
    <Setter Property="Padding" Value="20,12" />
  </Style>

  <!-- ── buttons (hover lightens one step + line-3; press = 1px down, no scale) ── -->

  <Style Selector="Button">
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="FontSize" Value="13" />
    <Setter Property="Transitions">
      <Transitions>
        <!-- fast 120 / ease-out: hover + press -->
        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="Button:pressed">
    <Setter Property="RenderTransform" Value="translate(0px, 1px)" />
  </Style>

  <Style Selector="Button.vx-primary">
    <Setter Property="Background" Value="{StaticResource VxAccentBrush}" />
    <Setter Property="Foreground" Value="{StaticResource VxOnAccentBrush}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Padding" Value="13,6" />
  </Style>
  <Style Selector="Button.vx-primary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource VxAccent2Brush}" />
    <Setter Property="Foreground" Value="{StaticResource VxOnAccentBrush}" />
  </Style>
  <Style Selector="Button.vx-primary:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource VxAccentPressedBrush}" />
    <Setter Property="Foreground" Value="{StaticResource VxOnAccentBrush}" />
  </Style>
  <Style Selector="Button.vx-primary:disabled /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource VxAccentDimBrush}" />
    <Setter Property="Foreground" Value="{StaticResource VxMutedBrush}" />
  </Style>

  <Style Selector="Button.vx-secondary">
    <Setter Property="Background" Value="{StaticResource VxRaisedBrush}" />
    <Setter Property="Foreground" Value="{StaticResource VxTextBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine2Brush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="11,6" />
  </Style>
  <Style Selector="Button.vx-secondary:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource VxInk700Brush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine3Brush}" />
  </Style>

  <Style Selector="Button.vx-ghost">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource VxText2Brush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine2Brush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="11,6" />
  </Style>
  <Style Selector="Button.vx-ghost:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource VxRaisedBrush}" />
    <Setter Property="Foreground" Value="{StaticResource VxTextBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine3Brush}" />
  </Style>

  <Style Selector="Button.vx-danger">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource VxBadBrush}" />
    <Setter Property="BorderBrush" Value="#59EF5350" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="11,6" />
  </Style>
  <Style Selector="Button.vx-danger:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource VxBadSoftBrush}" />
    <Setter Property="Foreground" Value="{StaticResource VxBadBrush}" />
  </Style>

  <!-- ── nav rail: icon + 10px label, active = card bg + hairline + cyan + edge bar ── -->

  <Style Selector="RadioButton.vx-nav">
    <!-- Fluent's RadioButton defaults to HorizontalAlignment=Left — without Stretch the
         active card hugs the icon instead of spanning the rail (the kit's card is full-width
         minus the 6px gutters, icon AND label inside). -->
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <Border Name="navBorder"
                  Margin="6,2"
                  CornerRadius="10"
                  Background="Transparent"
                  BorderThickness="1"
                  BorderBrush="Transparent"
                  Padding="4,11">
            <StackPanel Spacing="5" HorizontalAlignment="Center">
              <ContentPresenter Name="PART_ContentPresenter"
                                Content="{TemplateBinding Content}"
                                HorizontalAlignment="Center" />
              <TextBlock Name="navLabel"
                         Text="{TemplateBinding Tag}"
                         FontSize="10" FontWeight="Medium"
                         HorizontalAlignment="Center"
                         Foreground="{StaticResource VxMutedBrush}" />
            </StackPanel>
          </Border>
          <!-- Active edge bar sits at the rail's absolute left edge, inset 14px top/bottom. -->
          <Rectangle Name="navAccent"
                     Width="2" RadiusX="1" RadiusY="1"
                     HorizontalAlignment="Left"
                     Margin="0,14"
                     Fill="{StaticResource VxAccentBrush}"
                     IsVisible="False" />
        </Panel>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="RadioButton.vx-nav /template/ Border#navBorder">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="RadioButton.vx-nav:pointerover /template/ TextBlock#navLabel">
    <Setter Property="Foreground" Value="{StaticResource VxTextBrush}" />
  </Style>
  <Style Selector="RadioButton.vx-nav:checked /template/ Border#navBorder">
    <Setter Property="Background" Value="{StaticResource VxPanel2Brush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine1Brush}" />
  </Style>
  <Style Selector="RadioButton.vx-nav:checked /template/ TextBlock#navLabel">
    <Setter Property="Foreground" Value="{StaticResource VxAccentBrush}" />
  </Style>
  <Style Selector="RadioButton.vx-nav:checked /template/ Rectangle#navAccent">
    <Setter Property="IsVisible" Value="True" />
  </Style>
  <Style Selector="RadioButton.vx-nav PathIcon">
    <Setter Property="Foreground" Value="{StaticResource VxMutedBrush}" />
    <Setter Property="Width" Value="17" />
    <Setter Property="Height" Value="17" />
  </Style>
  <Style Selector="RadioButton.vx-nav:pointerover PathIcon">
    <Setter Property="Foreground" Value="{StaticResource VxTextBrush}" />
  </Style>
  <Style Selector="RadioButton.vx-nav:checked PathIcon">
    <Setter Property="Foreground" Value="{StaticResource VxAccentBrush}" />
  </Style>

  <!-- ── segmented switch (the Playgrounds STT|TTS selector, source strips) ── -->

  <Style Selector="Border.vx-seg-track">
    <Setter Property="Background" Value="{StaticResource VxRaisedBrush}" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="Padding" Value="3" />
  </Style>

  <Style Selector="RadioButton.vx-seg">
    <Setter Property="Template">
      <ControlTemplate>
        <Border Name="segBorder" CornerRadius="7" Background="Transparent" Padding="11,5">
          <ContentPresenter Content="{TemplateBinding Content}"
                            HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
      </ControlTemplate>
    </Setter>
    <Setter Property="Foreground" Value="{StaticResource VxText2Brush}" />
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
  <Style Selector="RadioButton.vx-seg /template/ Border#segBorder">
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="RadioButton.vx-seg:pointerover">
    <Setter Property="Foreground" Value="{StaticResource VxTextBrush}" />
  </Style>
  <!-- Active segment: cyan fill, ink text — never white on cyan. -->
  <Style Selector="RadioButton.vx-seg:checked /template/ Border#segBorder">
    <Setter Property="Background" Value="{StaticResource VxAccentBrush}" />
  </Style>
  <Style Selector="RadioButton.vx-seg:checked">
    <Setter Property="Foreground" Value="{StaticResource VxOnAccentBrush}" />
  </Style>

  <!-- Disclosure section header: chevron + caps label; content elsewhere binds IsChecked.
       Progressive disclosure is the calm-by-default rule (P2) applied to power features. -->
  <Style Selector="ToggleButton.vx-section">
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="Transparent" Padding="2,4">
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Path Name="chev" Data="M0,0 L5,5 L0,10"
                  Stroke="{StaticResource VxMutedBrush}" StrokeThickness="1.5"
                  VerticalAlignment="Center"
                  RenderTransform="rotate(0deg)">
              <Path.Transitions>
                <Transitions>
                  <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.12" />
                </Transitions>
              </Path.Transitions>
            </Path>
            <ContentPresenter Content="{TemplateBinding Content}" VerticalAlignment="Center" />
          </StackPanel>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="ToggleButton.vx-section:checked /template/ Path#chev">
    <Setter Property="RenderTransform" Value="rotate(90deg)" />
  </Style>
  <Style Selector="ToggleButton.vx-section:pointerover /template/ Path#chev">
    <Setter Property="Stroke" Value="{StaticResource VxTextBrush}" />
  </Style>

  <!-- Quiet row affordances: nearly silent until the row is hovered (or the state is active). -->
  <Style Selector="ListBoxItem Button.vx-quiet">
    <Setter Property="Opacity" Value="0.35" />
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="Opacity" Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>
  <Style Selector="ListBoxItem:pointerover Button.vx-quiet">
    <Setter Property="Opacity" Value="1" />
  </Style>
  <Style Selector="ListBoxItem Button.vx-quiet.pinned">
    <Setter Property="Opacity" Value="1" />
  </Style>

  <!-- Stress-phrase chips: mono pills that load the deck into the text box. -->
  <Style Selector="Button.vx-phrase">
    <Setter Property="Background" Value="{StaticResource VxPanel2Brush}" />
    <Setter Property="Foreground" Value="{StaticResource VxText2Brush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine2Brush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="FontFamily" Value="{StaticResource VxMono}" />
    <Setter Property="FontSize" Value="11" />
  </Style>
  <Style Selector="Button.vx-phrase:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource VxRaisedBrush}" />
    <Setter Property="Foreground" Value="{StaticResource VxTextBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine3Brush}" />
  </Style>

  <!-- ── inputs: surface-2, line-2 border, radius 10, cyan on focus ── -->

  <Style Selector="ComboBox">
    <Setter Property="Background" Value="{StaticResource VxPanel2Brush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine2Brush}" />
    <Setter Property="CornerRadius" Value="10" />
  </Style>
  <Style Selector="ComboBox:pointerover /template/ Border#Background">
    <Setter Property="BorderBrush" Value="{StaticResource VxLine3Brush}" />
  </Style>

  <Style Selector="TextBox">
    <Setter Property="Background" Value="{StaticResource VxPanel2Brush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine2Brush}" />
    <Setter Property="CornerRadius" Value="10" />
    <Setter Property="SelectionBrush" Value="{StaticResource VxAccentDimBrush}" />
  </Style>
  <Style Selector="TextBox:focus /template/ Border#PART_BorderElement">
    <Setter Property="BorderBrush" Value="{StaticResource VxAccentBrush}" />
  </Style>

  <!-- ── lists ──────────────────────────────────────────────────────────── -->

  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
  </Style>
  <Style Selector="ListBoxItem">
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="Padding" Value="9,6" />
  </Style>
  <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource VxAccentDimBrush}" />
  </Style>

  <!-- ── status dots (7px; live = cyan, pulsing only while data-backed) ── -->

  <Style Selector="Ellipse.vx-dot">
    <Setter Property="Width" Value="7" />
    <Setter Property="Height" Value="7" />
  </Style>

  <!-- Live dot pulses (the only idle loop besides the logo glow); colour carries the state if reduced. -->
  <Style Selector="Ellipse.vx-dot.vx-live">
    <Setter Property="Fill" Value="{StaticResource VxAccentBrush}" />
    <Style.Animations>
      <Animation Duration="0:0:1.6" IterationCount="INFINITE" Easing="SineEaseInOut">
        <KeyFrame Cue="0%"><Setter Property="Opacity" Value="1" /></KeyFrame>
        <KeyFrame Cue="50%"><Setter Property="Opacity" Value="0.35" /></KeyFrame>
        <KeyFrame Cue="100%"><Setter Property="Opacity" Value="1" /></KeyFrame>
      </Animation>
    </Style.Animations>
  </Style>

  <!-- ── badge: mono UPPERCASE pill, 1 of 7 tones (soft fill + ~30% border + tone text).
       Text inherits via TextElement.* so a bare <TextBlock> child picks up font + colour. ── -->
  <Style Selector="Border.vx-badge">
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="Padding" Value="9,2" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Background" Value="{StaticResource VxRaisedBrush}" />
    <Setter Property="BorderBrush" Value="{StaticResource VxLine2Brush}" />
    <Setter Property="TextElement.Foreground" Value="{StaticResource VxText2Brush}" />
    <Setter Property="TextElement.FontFamily" Value="{StaticResource VxMono}" />
    <Setter Property="TextElement.FontSize" Value="10" />
    <Setter Property="TextElement.FontWeight" Value="Medium" />
  </Style>
  <Style Selector="Border.vx-badge TextBlock">
    <Setter Property="LetterSpacing" Value="0.6" />
  </Style>
  <Style Selector="Border.vx-badge.pulse">
    <Setter Property="Background" Value="{StaticResource VxAccentDimBrush}" />
    <Setter Property="BorderBrush" Value="#4D4FC3F7" />
    <Setter Property="TextElement.Foreground" Value="{StaticResource VxAccent2Brush}" />
  </Style>
  <Style Selector="Border.vx-badge.info">
    <Setter Property="Background" Value="{StaticResource VxAccentDimBrush}" />
    <Setter Property="BorderBrush" Value="#4D4FC3F7" />
    <Setter Property="TextElement.Foreground" Value="{StaticResource VxAccentBrush}" />
  </Style>
  <Style Selector="Border.vx-badge.halo">
    <Setter Property="Background" Value="{StaticResource VxHaloSoftBrush}" />
    <Setter Property="BorderBrush" Value="#4DCE93D8" />
    <Setter Property="TextElement.Foreground" Value="{StaticResource VxHaloBrush}" />
  </Style>
  <Style Selector="Border.vx-badge.ok">
    <Setter Property="Background" Value="{StaticResource VxGoodSoftBrush}" />
    <Setter Property="BorderBrush" Value="#4D66BB6A" />
    <Setter Property="TextElement.Foreground" Value="{StaticResource VxGoodBrush}" />
  </Style>
  <Style Selector="Border.vx-badge.warn">
    <Setter Property="Background" Value="{StaticResource VxWarnSoftBrush}" />
    <Setter Property="BorderBrush" Value="#4DFFB74D" />
    <Setter Property="TextElement.Foreground" Value="{StaticResource VxWarnBrush}" />
  </Style>
  <Style Selector="Border.vx-badge.danger">
    <Setter Property="Background" Value="{StaticResource VxBadSoftBrush}" />
    <Setter Property="BorderBrush" Value="#4DEF5350" />
    <Setter Property="TextElement.Foreground" Value="{StaticResource VxBadBrush}" />
  </Style>

  <!-- ── voice orb: layered cyan radial sphere + glow; rings ripple outward when live (Talk). ── -->
  <Style Selector="controls|VoiceOrb">
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <!-- ripple rings: hidden until live, then scale + fade outward (staggered).
               Each owns a ScaleTransform so the keyframes animate ScaleTransform.ScaleX/Y. -->
          <Ellipse Name="ripple1" Stroke="#594FC3F7" StrokeThickness="1" Fill="Transparent"
                   Opacity="0" RenderTransformOrigin="50%,50%">
            <Ellipse.RenderTransform><ScaleTransform ScaleX="0.9" ScaleY="0.9" /></Ellipse.RenderTransform>
          </Ellipse>
          <Ellipse Name="ripple2" Stroke="#594FC3F7" StrokeThickness="1" Fill="Transparent"
                   Opacity="0" RenderTransformOrigin="50%,50%">
            <Ellipse.RenderTransform><ScaleTransform ScaleX="0.9" ScaleY="0.9" /></Ellipse.RenderTransform>
          </Ellipse>
          <!-- body: outer glow + inner darkening, three stacked radial gradients (highlight on top) -->
          <Border CornerRadius="1000" BoxShadow="0 0 40 0 #594FC3F7, inset 0 0 24 0 #660B0F14">
            <Panel>
              <Ellipse>
                <Ellipse.Fill>
                  <RadialGradientBrush Center="40%,55%" GradientOrigin="40%,55%" RadiusX="0.7" RadiusY="0.7">
                    <GradientStop Offset="0" Color="#EB4FC3F7" />
                    <GradientStop Offset="1" Color="#B8155F82" />
                  </RadialGradientBrush>
                </Ellipse.Fill>
              </Ellipse>
              <Ellipse>
                <Ellipse.Fill>
                  <RadialGradientBrush Center="64%,70%" GradientOrigin="64%,70%" RadiusX="0.6" RadiusY="0.6">
                    <GradientStop Offset="0" Color="#8C29A8E0" />
                    <GradientStop Offset="1" Color="#0029A8E0" />
                  </RadialGradientBrush>
                </Ellipse.Fill>
              </Ellipse>
              <Ellipse>
                <Ellipse.Fill>
                  <RadialGradientBrush Center="32%,28%" GradientOrigin="32%,28%" RadiusX="0.45" RadiusY="0.45">
                    <GradientStop Offset="0" Color="#38EAF1F8" />
                    <GradientStop Offset="1" Color="#00EAF1F8" />
                  </RadialGradientBrush>
                </Ellipse.Fill>
              </Ellipse>
            </Panel>
          </Border>
        </Panel>
      </ControlTemplate>
    </Setter>
  </Style>
  <Style Selector="controls|VoiceOrb[IsLive=True] /template/ Ellipse#ripple1">
    <Style.Animations>
      <Animation Duration="0:0:2.4" IterationCount="INFINITE" Easing="CubicEaseOut">
        <KeyFrame Cue="0%">
          <Setter Property="Opacity" Value="0.8" />
          <Setter Property="ScaleTransform.ScaleX" Value="0.9" />
          <Setter Property="ScaleTransform.ScaleY" Value="0.9" />
        </KeyFrame>
        <KeyFrame Cue="100%">
          <Setter Property="Opacity" Value="0" />
          <Setter Property="ScaleTransform.ScaleX" Value="1.45" />
          <Setter Property="ScaleTransform.ScaleY" Value="1.45" />
        </KeyFrame>
      </Animation>
    </Style.Animations>
  </Style>
  <Style Selector="controls|VoiceOrb[IsLive=True] /template/ Ellipse#ripple2">
    <Style.Animations>
      <Animation Duration="0:0:2.4" Delay="0:0:1.2" IterationCount="INFINITE" Easing="CubicEaseOut">
        <KeyFrame Cue="0%">
          <Setter Property="Opacity" Value="0.8" />
          <Setter Property="ScaleTransform.ScaleX" Value="0.9" />
          <Setter Property="ScaleTransform.ScaleY" Value="0.9" />
        </KeyFrame>
        <KeyFrame Cue="100%">
          <Setter Property="Opacity" Value="0" />
          <Setter Property="ScaleTransform.ScaleX" Value="1.45" />
          <Setter Property="ScaleTransform.ScaleY" Value="1.45" />
        </KeyFrame>
      </Animation>
    </Style.Animations>
  </Style>

  <!-- ── status pill: mono caps label + 7px dot; live dot pulses cyan (uses the vx-dot rule). ── -->
  <Style Selector="StackPanel.vx-status">
    <Setter Property="Orientation" Value="Horizontal" />
    <Setter Property="Spacing" Value="7" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextElement.FontFamily" Value="{StaticResource VxMono}" />
    <Setter Property="TextElement.FontSize" Value="10" />
    <Setter Property="TextElement.Foreground" Value="{StaticResource VxText2Brush}" />
  </Style>
  <Style Selector="StackPanel.vx-status.vx-live">
    <Setter Property="TextElement.Foreground" Value="{StaticResource VxAccent2Brush}" />
  </Style>

</Styles>
