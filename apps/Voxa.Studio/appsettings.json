{
  // Voxa Studio default pipeline: the keyless local tier (VLS-001). First use downloads the
  // pinned models into the shared cache; after that everything runs offline on this machine.
  // Cloud providers (OpenAI, Azure, ElevenLabs, Mistral) light up automatically if their keys
  // are present in user-secrets or environment variables — nothing here requires them.
  "Voxa": {
    "Stt": "WhisperCpp",
    "Tts": "Piper",
    "Agent": { "Provider": "Echo" },
    "WhisperCpp": { "Model": "tiny.en" },
    "Piper": { "Voice": "en_US-amy-low" },

    // Studio IS the diagnostics renderer — the hub, the taps, and the VAD observer are its
    // Talk view's data source.
    "Diagnostics": { "Enabled": true },

    // Models download on first use from the Talk/Voices views (with visible progress) rather
    // than at app start — Studio never touches the network before the user acts.
    "Models": { "EagerWarmup": false }
  }
}
